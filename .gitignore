/target
**/*.rs.bk
.DS_Store

# === handoff continuity kernel — canonical .handoff durability policy (ADR-0016 / ADR-0018 D1) ===
# REGENERABLE .handoff state — the LOCAL rebuild cache (the binary ledger is re-derived from the
# committed `.handoff/ledger.events.jsonl` via `hf import`) + ephemeral runtime + out-of-tree
# migration artifacts: never commit. The committed continuity truth is the JSONL export and the
# rendered views (packets/, active.md, deliveries/) — those are DURABLE and intentionally absent
# here so they stay committed (ADR-0018 D1).
# CONTENTS-FORM only — NEVER a bare `.handoff/` or `.claude/` ignore: Git cannot re-include a
# path past an excluded parent dir, so a dir-form ignore silently SWALLOWS durable ledgers
# (tasks/, decisions/, loop/*.md). Run `hf gitignore --check` (or `hf doctor`) to detect it.
.handoff/**/ledger.db
.handoff/**/*.db-wal
.handoff/**/*.db-shm
.handoff/**/*.rvf
.handoff/**/*.rvf.lock
.handoff/**/*.sqlite.bak
.handoff/**/*.redb.tmp
/.handoff/workspaces/
/.handoff/locks/

# === repo-local runner operations root ===
# Preserve _work topology/evidence; ignore only proven heavyweight/generated payloads.
_work/**/*.tar
_work/**/*.tar.*
_work/**/*.tgz
_work/**/*.zip
!_work/**/*.sha256
_work/**/target/
_work/**/externals/
_work/**/_actions/
_work/**/_temp/
_work/**/_tool/
_work/**/.cargo/registry/
_work/**/.cargo/git/
_work/**/.cargo/advisory-db/
_work/**/.rustup/toolchains/
_work/**/.rustup/downloads/
_work/**/.rustup/tmp/
_work/**/.cache/icm/models/
_work/**/.cache/gh/
_work/**/.cache/kache/store/
_work/**/.git/
# Nested checkout roots inside runner workspaces would become useless gitlinks
# without .gitmodules; preserve their pipeline mapping/state, not embedded repos.
_work/actions-runner-*-work/envctl/envctl/
_work/actions-runner-*-work/envctl/loop_lib/
_work/actions-runner-*-work/envctl/meta_plugin_protocol/
_work/actions-runner-*-work/flexnetos_runner/flexnetos_runner/
_work/actions-runner-*-work/meta/meta/
_work/**/.claude/plugins/marketplaces/*/
_work/**/_diag/
_work/**/bin/
_work/**/actions-runner-linux-*.tar.gz
