-{}-{stem}-{n}\", std::process::id()))\ncrates/runner-dispatch/src/main.rs:3938:        let log_path = unique(\"audit.ndjson\");\ncrates/runner-dispatch/src/main.rs:3942:        // here, but the redactor registers it regardless).\ncrates/runner-dispatch/src/main.rs:3943:        let redactor = build_redactor(\"dispatch-key\").with_secret(SECRET);\ncrates/runner-dispatch/src/main.rs:3944:        assert!(redactor.is_active());\ncrates/runner-dispatch/src/main.rs:3954:            let sink = RedactingSink::new(file_sink, redactor.clone());\ncrates/runner-dispatch/src/main.rs:3981:                &redactor,\ncrates/runner-dispatch/src/main.rs:4010:        // (2) The on-disk audit log: the secret must not appear anywhere in the file.\ncrates/runner-dispatch/src/main.rs:4014:            \"secret leaked into the audit log:\\n{logged}\"\ncrates/runner-dispatch/src/main.rs:4018:            \"audit log should show the placeholder:\\n{logged}\"\ncrates/runner-dispatch/src/main.rs:4020:        assert!(logged.contains(\"kernel_failed\"), \"the failure was audited\");\ncrates/runner-dispatch/src/main.rs:4029:        let mut guard = LoopGuard::default();\ncrates/runner-dispatch/src/main.rs:4050:                &mut guard,\ncrates/runner-dispatch/src/main.rs:4079:            &mut guard,\ncrates/runner-dispatch/src/main.rs:4114:            \"no fingerprint entered the retry ledger\"\ncrates/runner-dispatch/src/main.rs:4121:        let mut guard = LoopGuard::default();\ncrates/runner-dispatch/src/main.rs:4140:            &mut guard,\ncrates/runner-dispatch/src/main.rs:4170:            &mut guard,\ncrates/runner-dispatch/src/main.rs:4198:        let recovered = RecordingInvoker::default();\ncrates/runner-dispatch/src/main.rs:4199:        let mut guard = LoopGuard::default();\ncrates/runner-dispatch/src/main.rs:4218:            &mut guard,\ncrates/runner-dispatch/src/main.rs:4242:            &recovered,\ncrates/runner-dispatch/src/main.rs:4250:            &mut guard,\ncrates/runner-dispatch/src/main.rs:4270:        assert_eq!(recovered.calls(), 1);\ncrates/runner-dispatch/src/main.rs:4369:    fn risk_score_climbs_with_failure_history_and_rides_the_audit_event() {\ncrates/runner-dispatch/src/main.rs:4495:            \"no fingerprint entered the retry ledger\"\ncrates/runner-dispatch/src/main.rs:4498:        // The audit event is the fixed-enum KernelFatal class (the no-text telemetry seam).\ncrates/runner-dispatch/src/main.rs:4541:        /// keys on pid + job id; a shared id would collide across the parallel test threads).\ncrates/runner-dispatch/src/main.rs:4571:                Delegation::Delivered(cost) => assert_eq!(cost, JobCost::new(1500, 7500)),\ncrates/runner-dispatch/src/main.rs:4572:                other => panic!(\"expected Delivered, got {:?}\", DelegDbg(&other)),\ncrates/runner-dispatch/src/main.rs:4592:                        \"stderr tail captured: {msg}\"\ncrates/runner-dispatch/src/main.rs:4682:                Delegation::Delivered(_)\ncrates/runner-dispatch/src/main.rs:4717:                Delegation::Delivered(_)\ncrates/runner-dispatch/src/main.rs:4734:                Delegation::Delivered(cost) => assert_eq!(cost, JobCost::ZERO),\ncrates/runner-dispatch/src/main.rs:4735:                other => panic!(\"expected Delivered ZERO, got {:?}\", DelegDbg(&other)),\ncrates/runner-dispatch/src/main.rs:4759:                    Delegation::Delivered(c) => write!(f, \"Delivered({c})\"),\n","exit_code":0,"status":"completed"}}
