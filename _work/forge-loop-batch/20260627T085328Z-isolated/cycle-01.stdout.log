 {\ncrates/runner-core/src/agent.rs:281:#[cfg(test)]\ncrates/runner-core/src/agent.rs:282:mod tests {\ncrates/runner-core/src/agent.rs:285:    #[test]\ncrates/runner-core/src/agent.rs:293:    #[test]\ncrates/runner-core/src/agent.rs:301:    #[test]\ncrates/runner-core/src/agent.rs:313:    #[test]\ncrates/runner-core/src/agent.rs:321:    #[test]\ncrates/runner-core/src/agent.rs:338:    #[test]\ncrates/runner-core/src/agent.rs:355:    #[test]\ncrates/runner-core/src/agent.rs:366:    #[test]\ncrates/runner-core/src/agent.rs:376:    #[test]\ncrates/runner-core/src/agent.rs:393:    #[test]\ncrates/runner-core/src/agent.rs:405:    #[test]\ncrates/runner-core/src/agent.rs:426:    #[test]\ncrates/runner-core/src/deadline.rs:8://! - the **loop breaker** ([`crate::loopguard`]) catches the same work dispatched *in a loop*;\ncrates/runner-core/src/deadline.rs:12://! None of them bounds a *single, non-looping, in-budget* job that simply **hangs** — never\ncrates/runner-core/src/deadline.rs:68:    pub fn is_active(&self) -> bool {\ncrates/runner-core/src/deadline.rs:69:        self.default_secs.is_some()\ncrates/runner-core/src/deadline.rs:73:    pub fn default_secs(&self) -> Option<u64> {\ncrates/runner-core/src/deadline.rs:74:        self.default_secs\ncrates/runner-core/src/deadline.rs:84:    pub fn effective(&self, job_requested: Option<u64>) -> Option<Duration> {\ncrates/runner-core/src/deadline.rs:86:        let secs = match (self.default_secs, requested) {\ncrates/runner-core/src/deadline.rs:96:#[cfg(test)]\ncrates/runner-core/src/deadline.rs:97:mod tests {\ncrates/runner-core/src/deadline.rs:100:    #[test]\ncrates/runner-core/src/deadline.rs:107:    #[test]\ncrates/runner-core/src/deadline.rs:113:    #[test]\ncrates/runner-core/src/deadline.rs:119:    #[test]\ncrates/runner-core/src/deadline.rs:128:    #[test]\ncrates/runner-core/src/redact.rs:1://! Secret redaction for the audit / error egress surfaces (adapted from `coleam00/Archon`'s\ncrates/runner-core/src/redact.rs: