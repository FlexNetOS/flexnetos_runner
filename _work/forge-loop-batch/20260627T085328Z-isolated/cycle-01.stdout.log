r.unwrap().contains(\"loop breaker\"));\ncrates/runner-dispatch/src/main.rs:2795:    #[test]\ncrates/runner-dispatch/src/main.rs:2849:    #[test]\ncrates/runner-dispatch/src/main.rs:2850:    fn reported_cost_charges_the_token_budget_and_lands_in_the_audit_log() {\ncrates/runner-dispatch/src/main.rs:2855:            fn emit(&self, e: &DispatchEvent) {\ncrates/runner-dispatch/src/main.rs:2856:                self.0.borrow_mut().push(e.clone());\ncrates/runner-dispatch/src/main.rs:2919:    #[test]\ncrates/runner-dispatch/src/main.rs:2969:    #[test]\ncrates/runner-dispatch/src/main.rs:2970:    fn grace_floor_lets_jobs_past_the_cap_then_halts_and_audits_the_tier() {\ncrates/runner-dispatch/src/main.rs:2976:            fn emit(&self, e: &DispatchEvent) {\ncrates/runner-dispatch/src/main.rs:2977:                self.0.borrow_mut().push(e.clone());\ncrates/runner-dispatch/src/main.rs:3040:        // The grace (distress) delegation is audited with a survival-tier note (the cap is met).\ncrates/runner-dispatch/src/main.rs:3052:            \"the over-cap grace admit should carry a halted-tier audit note\"\ncrates/runner-dispatch/src/main.rs:3056:    #[test]\ncrates/runner-dispatch/src/main.rs:3106:    #[test]\ncrates/runner-dispatch/src/main.rs:3116:        // Each call uses distinct work (varying sha) so the *loop breaker* never fires — we are\ncrates/runner-dispatch/src/main.rs:3188:    #[test]\ncrates/runner-dispatch/src/main.rs:3194:        // *loop breaker* never fires — we are exercising quarantine, an independent gate.\ncrates/runner-dispatch/src/main.rs:3319:    #[test]\ncrates/runner-dispatch/src/main.rs:3363:    #[test]\ncrates/runner-dispatch/src/main.rs:3393:    #[test]\ncrates/runner-dispatch/src/main.rs:3407:    #[test]\ncrates/runner-dispatch/src/main.rs:3408:    fn envelope_deadline_drives_a_timeout_through_recovery_and_the_audit_log() {\ncrates/runner-dispatch/src/main.rs:3414:            fn emit(&self, e: &DispatchEvent) {\ncrates/runner-dispatch/src/main.rs