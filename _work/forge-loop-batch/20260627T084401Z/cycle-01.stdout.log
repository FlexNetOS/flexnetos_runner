{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"rtk sed -n '1,220p' .github/workflows/runner-smoke.yml\"","aggregated_output":"name: Runner Smoke\n\non:\n  workflow_dispatch:\n    inputs:\n      expected_runner:\n        description: Expected GitHub Actions runner name\n        required: true\n        type: string\n      expected_slot:\n        description: Expected repo-local runner slot suffix, for example 01 or 02\n        required: true\n        type: string\n\npermissions:\n  contents: read\n\njobs:\n  smoke:\n    name: Runner smoke\n    runs-on: [self-hosted, linux, x64, local, flexnetos]\n    steps:\n      - name: Verify runner identity and repo-local paths\n        shell: bash\n        run: |\n          set -euo pipefail\n          echo \"expected_runner=${{ inputs.expected_runner }}\"\n          echo \"actual_runner=${RUNNER_NAME}\"\n          echo \"expected_slot=${{ inputs.expected_slot }}\"\n          echo \"runner_os=${RUNNER_OS}\"\n          echo \"runner_arch=${RUNNER_ARCH}\"\n          echo \"runner_tracking_id=${RUNNER_TRACKING_ID:-unset}\"\n          echo \"runner_workspace=${RUNNER_WORKSPACE}\"\n          echo \"pwd=$(pwd)\"\n          echo \"hostname=$(hostname)\"\n          echo \"whoami=$(whoami)\"\n          echo \"date_utc=$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n          test \"${RUNNER_NAME}\" = \"${{ inputs.expected_runner }}\"\n          case \"${RUNNER_WORKSPACE}\" in\n            /home/drdave/Desktop/meta/flexnetos_runner/_work/actions-runner-${{ inputs.expected_slot }}-work/*) ;;\n            *)\n              echo \"RUNNER_WORKSPACE is not under the expected repo-local slot\" >&2\n              exit 1\n              ;;\n          esac\n","exit_code":0,"status":"completed"}}
