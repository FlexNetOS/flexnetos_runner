{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Forge Loop Run Output",
  "type": "object",
  "required": [
    "summary",
    "sources_mined",
    "component_inventory",
    "verification",
    "auto_compact_continuity"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string"
    },
    "sources_mined": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "url",
          "finding"
        ],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          }
        }
      }
    },
    "component_inventory": {
      "type": "object",
      "required": [
        "config",
        "hooks",
        "rules",
        "skills",
        "agents",
        "permissions",
        "github_action"
      ],
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string"
        },
        "hooks": {
          "type": "string"
        },
        "rules": {
          "type": "string"
        },
        "skills": {
          "type": "string"
        },
        "agents": {
          "type": "string"
        },
        "permissions": {
          "type": "string"
        },
        "github_action": {
          "type": "string"
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auto_compact_continuity": {
      "type": "object",
      "required": [
        "enabled",
        "compact_prompt",
        "preserved_state",
        "active_phase",
        "source_coverage",
        "validation_state",
        "next_action"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "compact_prompt": {
          "type": "string"
        },
        "preserved_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_phase": {
          "type": "string"
        },
        "source_coverage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        }
      }
    }
  }
}
