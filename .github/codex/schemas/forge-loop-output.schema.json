{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Forge Loop Run Output",
  "type": "object",
  "required": [
    "summary",
    "auth_mode",
    "auth_evidence",
    "sources_mined",
    "component_inventory",
    "recommended_self_upgrade",
    "tests_required_before_merge",
    "verification",
    "auto_compact_continuity"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string"
    },
    "auth_mode": {
      "type": "string",
      "enum": [
        "api_key",
        "local_chatgpt"
      ]
    },
    "auth_evidence": {
      "type": "object",
      "required": [
        "codex_home",
        "login_status_checked",
        "auth_json_present"
      ],
      "additionalProperties": false,
      "properties": {
        "codex_home": {
          "type": "string"
        },
        "login_status_checked": {
          "type": "boolean"
        },
        "auth_json_present": {
          "type": "boolean"
        }
      }
    },
    "sources_mined": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "url",
          "finding"
        ],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          }
        }
      }
    },
    "component_inventory": {
      "type": "object",
      "required": [
        "config",
        "hooks",
        "rules",
        "skills",
        "agents",
        "permissions",
        "github_action",
        "model_flags",
        "tool_surfaces",
        "structured_output_schemas",
        "auto_compaction_continuity_settings"
      ],
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string"
        },
        "hooks": {
          "type": "string"
        },
        "rules": {
          "type": "string"
        },
        "skills": {
          "type": "string"
        },
        "agents": {
          "type": "string"
        },
        "permissions": {
          "type": "string"
        },
        "github_action": {
          "type": "string"
        },
        "model_flags": {
          "type": "string"
        },
        "tool_surfaces": {
          "type": "string"
        },
        "structured_output_schemas": {
          "type": "string"
        },
        "auto_compaction_continuity_settings": {
          "type": "string"
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_self_upgrade": {
      "type": "string"
    },
    "tests_required_before_merge": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auto_compact_continuity": {
      "type": "object",
      "required": [
        "enabled",
        "compact_prompt",
        "preserved_state",
        "active_phase",
        "source_coverage",
        "validation_state",
        "validation_terminal_state",
        "validation_sources",
        "phase_continuity",
        "next_action"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "compact_prompt": {
          "type": "string"
        },
        "preserved_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_phase": {
          "type": "string"
        },
        "source_coverage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_terminal_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase_continuity": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        }
      }
    }
  }
}
